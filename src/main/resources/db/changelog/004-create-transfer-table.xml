<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004-create-transfer-table" author="developer">
        <createTable tableName="transfer">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="balance" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP"/>
            <column name="card_from_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="card_to_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Внешние ключи -->
        <addForeignKeyConstraint
                baseTableName="transfer"
                baseColumnNames="card_from_id"
                referencedTableName="card"
                referencedColumnNames="id"
                constraintName="fk_transfer_card_from"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="transfer"
                baseColumnNames="card_to_id"
                referencedTableName="card"
                referencedColumnNames="id"
                constraintName="fk_transfer_card_to"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="transfer"
                baseColumnNames="user_id"
                referencedTableName="user"
                referencedColumnNames="id"
                constraintName="fk_transfer_user"
                onDelete="CASCADE"/>

        <!-- Индексы -->
        <createIndex tableName="transfer" indexName="idx_transfer_card_from_id">
            <column name="card_from_id"/>
        </createIndex>

        <createIndex tableName="transfer" indexName="idx_transfer_card_to_id">
            <column name="card_to_id"/>
        </createIndex>

        <createIndex tableName="transfer" indexName="idx_transfer_user_id">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="transfer" indexName="idx_transfer_created">
            <column name="created"/>
        </createIndex>

        <rollback>
            <dropTable tableName="transfer"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
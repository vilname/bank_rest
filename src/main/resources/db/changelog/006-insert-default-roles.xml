<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="006-insert-default-roles" author="developer">
        <!-- Вставляем роли с UUID -->
        <insert tableName="role">
            <column name="id" valueNumeric="gen_random_uuid()"/>
            <column name="name" value="ROLE_USER"/>
        </insert>
        <insert tableName="role">
            <column name="id" valueNumeric="gen_random_uuid()"/>
            <column name="name" value="ROLE_ADMIN"/>
        </insert>
        <insert tableName="role">
            <column name="id" valueNumeric="gen_random_uuid()"/>
            <column name="name" value="ROLE_MODERATOR"/>
        </insert>

        <rollback>
            <delete tableName="role">
                <where>name IN ('ROLE_USER', 'ROLE_ADMIN', 'ROLE_MODERATOR')</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
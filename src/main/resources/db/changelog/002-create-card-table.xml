<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-card-table" author="developer">
        <createTable tableName="card">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="number" type="INT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="balance" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="owner" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="expiry_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP"/>
            <column name="updated" type="TIMESTAMP"/>
        </createTable>

        <!-- Добавляем внешний ключ к user -->
        <addForeignKeyConstraint
                baseTableName="card"
                baseColumnNames="user_id"
                referencedTableName="user"
                referencedColumnNames="id"
                constraintName="fk_card_user"
                onDelete="CASCADE"/>

        <!-- Добавляем индексы для оптимизации -->
        <createIndex tableName="card" indexName="idx_card_user_id">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="card" indexName="idx_card_status">
            <column name="status"/>
        </createIndex>

        <createIndex tableName="card" indexName="idx_card_expiry_date">
            <column name="expiry_date"/>
        </createIndex>

        <rollback>
            <dropTable tableName="card"/>
        </rollback>
    </changeSet>

</databaseChangeLog>